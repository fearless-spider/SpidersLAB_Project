#!/bin/sh
# Spider-Sense AI Status — Waybar module
# Three states: idle / active (>10% GPU) / generating (>50% GPU)

gpu_usage=0
if command -v nvidia-smi >/dev/null 2>&1; then
    gpu_usage=$(nvidia-smi pmon -c 1 -s u 2>/dev/null \
        | awk '/ollama/{sum+=$4} END{printf "%d", sum+0}')
fi

if [ "$gpu_usage" -gt 50 ] 2>/dev/null; then
    printf '{"text":"󰚩 %d%%","class":"generating","tooltip":"Spider-Sense GENERATING — GPU: %d%%"}\n' "$gpu_usage" "$gpu_usage"
elif [ "$gpu_usage" -gt 10 ] 2>/dev/null; then
    printf '{"text":"󰚩 %d%%","class":"active","tooltip":"Spider-Sense ACTIVE — GPU: %d%%"}\n' "$gpu_usage" "$gpu_usage"
else
    printf '{"text":"󰚩","class":"idle","tooltip":"Spider-Sense idle"}\n'
fi
