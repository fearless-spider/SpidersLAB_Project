#!/bin/bash
# ╔══════════════════════════════════════════════════════════════════════╗
# ║  SPIDER'S LAB — GHOST PROTOCOL                                     ║
# ║                                                                     ║
# ║  "Hack the planet!" — but leave no trace.                          ║
# ║                                                                     ║
# ║  Cinematic session wipe + system exit.                              ║
# ║  The spider vanishes from the web.                                  ║
# ║                                                                     ║
# ║  Usage:  ghost-out              — wipe & poweroff                   ║
# ║          ghost-out --reboot     — wipe & reboot                     ║
# ║          ghost-out --logout     — wipe & exit Hyprland only         ║
# ║          ghost-out --force      — skip confirmation                 ║
# ╚══════════════════════════════════════════════════════════════════════╝

set -euo pipefail

# ── ANSI arsenal ─────────────────────────────────────────────────────
RED='\e[31m'
BRED='\e[1;31m'
DRED='\e[2;31m'
CYAN='\e[36m'
BCYAN='\e[1;36m'
DIM='\e[2m'
BOLD='\e[1m'
RESET='\e[0m'

COLS=$(tput cols 2>/dev/null || echo 80)
ROWS=$(tput lines 2>/dev/null || echo 24)

# ── Parse flags ──────────────────────────────────────────────────────
ACTION="poweroff"
FORCE=false

for arg in "$@"; do
    case "$arg" in
        --reboot)  ACTION="reboot"  ;;
        --logout)  ACTION="logout"  ;;
        --force)   FORCE=true       ;;
    esac
done

# ── Sound effect (async — doesn't block the animation) ───────────────
_play_shutdown_sound() {
    local snd="/usr/share/spiderslab/sounds/shutdown.wav"
    if [[ -f "$snd" ]]; then
        if command -v paplay &>/dev/null; then
            paplay "$snd" &>/dev/null &
        elif command -v mpv &>/dev/null; then
            mpv --no-video --really-quiet "$snd" &>/dev/null &
        fi
    else
        # Fallback: freedesktop power-off sound
        local fb="/usr/share/sounds/freedesktop/stereo/service-logout.oga"
        if [[ -f "$fb" ]]; then
            if command -v paplay &>/dev/null; then
                paplay "$fb" &>/dev/null &
            elif command -v mpv &>/dev/null; then
                mpv --no-video --really-quiet "$fb" &>/dev/null &
            fi
        fi
    fi
}

# ══════════════════════════════════════════════════════════════════════
#  BANNER + CONFIRMATION
# ══════════════════════════════════════════════════════════════════════

clear
echo ""
echo -e "${BRED}"
cat << 'GHOST'
    ██████╗ ██╗  ██╗ ██████╗ ███████╗████████╗
   ██╔════╝ ██║  ██║██╔═══██╗██╔════╝╚══██╔══╝
   ██║  ███╗███████║██║   ██║███████╗   ██║
   ██║   ██║██╔══██║██║   ██║╚════██║   ██║
   ╚██████╔╝██║  ██║╚██████╔╝███████║   ██║
    ╚═════╝ ╚═╝  ╚═╝ ╚═════╝ ╚══════╝   ╚═╝
GHOST
echo -e "${RESET}"
echo -e "   ${BCYAN}── P R O T O C O L ──${RESET}"
echo ""
echo -e "   ${DIM}Target action:${RESET} ${BRED}${ACTION}${RESET}"
echo ""
echo -e "   ${DIM}This will:${RESET}"
echo -e "     ${RED}▸${RESET} Shred shell history (zsh, bash, python, node)"
echo -e "     ${RED}▸${RESET} Wipe clipboard (cliphist + wl-copy)"
echo -e "     ${RED}▸${RESET} Purge recent files & thumbnails"
echo -e "     ${RED}▸${RESET} Clear browser session data"
echo -e "     ${RED}▸${RESET} Flush DNS & ARP cache"
echo -e "     ${RED}▸${RESET} Purge /tmp spider artifacts"
echo -e "     ${RED}▸${RESET} Exit Hyprland compositor"
echo ""

if [[ "$FORCE" != true ]]; then
    echo -ne "   ${BRED}Vanish from the web? [y/N]${RESET} "
    read -r -t 15 CONFIRM || CONFIRM="n"
    if [[ "$CONFIRM" != "y" && "$CONFIRM" != "Y" ]]; then
        echo -e "\n   ${CYAN}Ghost protocol aborted. You're still visible.${RESET}\n"
        exit 0
    fi
fi

# Start shutdown sound immediately
_play_shutdown_sound

# ══════════════════════════════════════════════════════════════════════
#  PHASE 1: GLITCH/MATRIX ANIMATION (2 seconds, Spider-Red)
# ══════════════════════════════════════════════════════════════════════

clear
printf '\e[?25l'  # hide cursor

# Glitch character set — katakana + hex + symbols
GLITCH_CHARS="01アイウエオカキクケコサシスセソタチツテトナニヌネノ@#$%&!<>{}[]|\\~:.;/=+*^"
GLEN=${#GLITCH_CHARS}

# Phase 1a: HIGH-SPEED RED GLITCH RAIN — ~1.2 seconds (40 frames @ 30ms)
for frame in $(seq 1 40); do
    # Calculate intensity: bright → dim across the animation
    if (( frame <= 15 )); then
        COLOR="${BRED}"
    elif (( frame <= 30 )); then
        COLOR="${RED}"
    else
        COLOR="${DRED}"
    fi

    # Scatter characters across terminal
    for _ in $(seq 1 $(( COLS / 3 ))); do
        ROW=$(( RANDOM % ROWS + 1 ))
        COL=$(( RANDOM % COLS + 1 ))
        CHAR="${GLITCH_CHARS:$(( RANDOM % GLEN )):1}"
        printf '\e[%d;%dH%b%s\e[0m' "$ROW" "$COL" "$COLOR" "$CHAR"
    done

    # Every 5 frames: glitch a full random line (screen tear effect)
    if (( frame % 5 == 0 )); then
        TEAR_ROW=$(( RANDOM % ROWS + 1 ))
        TEAR_LINE=""
        for _ in $(seq 1 "$COLS"); do
            TEAR_LINE+="${GLITCH_CHARS:$(( RANDOM % GLEN )):1}"
        done
        printf '\e[%d;1H%b%s\e[0m' "$TEAR_ROW" "$COLOR" "$TEAR_LINE"
    fi

    sleep 0.03
done

# Phase 1b: DISSOLVE TO BLACK — ~0.8 seconds (16 frames @ 50ms)
for frame in $(seq 1 16); do
    # Progressively blank out random positions
    for _ in $(seq 1 $(( COLS / 2 ))); do
        ROW=$(( RANDOM % ROWS + 1 ))
        COL=$(( RANDOM % COLS + 1 ))
        printf '\e[%d;%dH ' "$ROW" "$COL"
    done
    sleep 0.05
done

# Black screen
printf '\e[2J\e[H'
sleep 0.2

# ══════════════════════════════════════════════════════════════════════
#  PHASE 2: EVIDENCE DESTRUCTION — status readout
# ══════════════════════════════════════════════════════════════════════

# Draw the destruction HUD
_hud_line() {
    local tag=$1 msg=$2
    printf "   ${DIM}[${RESET}${BRED}${tag}${DIM}]${RESET}  ${msg}"
    sleep 0.08
}

_hud_ok() {
    echo -e " ${CYAN}done${RESET}"
}

echo ""
echo -e "   ${BRED}${BOLD}[!] CRITICAL: ERASING SESSION DATA...${RESET}"
echo ""
echo -e "   ${DIM}────────────────────────────────────────────${RESET}"
echo ""

# ── 2a: Clipboard ───────────────────────────────────────────────────
_hud_line "WIPE" "Clipboard history... "
if command -v cliphist &>/dev/null; then
    cliphist wipe 2>/dev/null
fi
if command -v wl-copy &>/dev/null; then
    echo -n "" | wl-copy 2>/dev/null
    echo -n "" | wl-copy -p 2>/dev/null
fi
_hud_ok

# ── 2b: Shell History ───────────────────────────────────────────────
_hud_line "SHRED" "Shell history (zsh/bash/python/node)... "
for hfile in \
    "$HOME/.zsh_history" \
    "$HOME/.bash_history" \
    "$HOME/.python_history" \
    "$HOME/.node_repl_history" \
    "$HOME/.lesshst" \
    "$HOME/.wget-hsts"; do
    if [[ -f "$hfile" ]]; then
        shred -fuz "$hfile" 2>/dev/null || rm -f "$hfile" 2>/dev/null
    fi
done
_hud_ok

# ── 2c: Recent Files & Thumbnails ───────────────────────────────────
_hud_line "WIPE" "Recent files & thumbnails... "
[[ -f "$HOME/.local/share/recently-used.xbel" ]] && \
    shred -fuz "$HOME/.local/share/recently-used.xbel" 2>/dev/null
rm -rf "$HOME/.cache/thunar/" 2>/dev/null
rm -rf "$HOME/.cache/thumbnails/" 2>/dev/null
rm -rf "$HOME/.local/share/Trash/"* 2>/dev/null
_hud_ok

# ── 2d: Browser Session Data ────────────────────────────────────────
_hud_line "WIPE" "Browser sessions (Firefox)... "
for profile in "$HOME"/.mozilla/firefox/*.default*; do
    if [[ -d "$profile" ]]; then
        rm -f "$profile/sessionstore.jsonlz4" 2>/dev/null
        rm -f "$profile/sessionstore-backups/"* 2>/dev/null
        rm -rf "$profile/storage/temporary/" 2>/dev/null
        rm -f "$profile/cookies.sqlite-wal" 2>/dev/null
    fi
done
_hud_ok

# ── 2e: DNS & Network Cache ─────────────────────────────────────────
_hud_line "FLUSH" "DNS & ARP cache... "
if systemctl is-active --quiet systemd-resolved 2>/dev/null; then
    resolvectl flush-caches 2>/dev/null
fi
ip neigh flush all 2>/dev/null
_hud_ok

# ── 2f: Temp Files ──────────────────────────────────────────────────
_hud_line "PURGE" "/tmp spider artifacts... "
rm -rf /tmp/spider-* 2>/dev/null
rm -rf /tmp/hypr/ 2>/dev/null
rm -rf "$HOME/.cache/wofi"* 2>/dev/null
_hud_ok

echo ""
echo -e "   ${DIM}────────────────────────────────────────────${RESET}"
echo -e "   ${BCYAN}${BOLD}All traces erased. Session clean.${RESET}"
echo ""

sleep 0.5

# ══════════════════════════════════════════════════════════════════════
#  PHASE 3: FAREWELL — centered message + fade
# ══════════════════════════════════════════════════════════════════════

clear

# Re-read terminal size after clear
COLS=$(tput cols 2>/dev/null || echo 80)
ROWS=$(tput lines 2>/dev/null || echo 24)

MSG="T H E   S P I D E R   V A N I S H E S"
MSG_LEN=${#MSG}
CENTER_COL=$(( (COLS - MSG_LEN) / 2 ))
CENTER_ROW=$(( ROWS / 2 ))

# Fade in with red glow
printf '\e[%d;%dH\e[2;31m%s\e[0m' "$CENTER_ROW" "$CENTER_COL" "$MSG"
sleep 0.3
printf '\e[%d;%dH\e[31m%s\e[0m' "$CENTER_ROW" "$CENTER_COL" "$MSG"
sleep 0.3
printf '\e[%d;%dH\e[1;31m%s\e[0m' "$CENTER_ROW" "$CENTER_COL" "$MSG"
sleep 1.0

# Fade out
printf '\e[%d;%dH\e[31m%s\e[0m' "$CENTER_ROW" "$CENTER_COL" "$MSG"
sleep 0.2
printf '\e[%d;%dH\e[2;31m%s\e[0m' "$CENTER_ROW" "$CENTER_COL" "$MSG"
sleep 0.2

# Black
printf '\e[2J\e[H\e[?25h'

# ══════════════════════════════════════════════════════════════════════
#  PHASE 4: EXIT — compositor + system
# ══════════════════════════════════════════════════════════════════════

# Kill Hyprland (triggers fade-out animation if configured)
if command -v hyprctl &>/dev/null; then
    hyprctl dispatch exit 2>/dev/null
    sleep 0.5
fi

# Final action
case "$ACTION" in
    poweroff) systemctl poweroff ;;
    reboot)   systemctl reboot   ;;
    logout)   exit 0             ;;
esac
