// ╔══════════════════════════════════════════════════════════════════════╗
// ║  SPIDER'S LAB — HOLOGRAPHIC WAYBAR                                ║
// ║                                                                    ║
// ║  "Hack the Planet." — Dade Murphy                                 ║
// ║                                                                    ║
// ║  Floating frosted panel. Neon-red border. Cyber-icons.            ║
// ║  The spider's neural HUD — Night City edition.                    ║
// ╚══════════════════════════════════════════════════════════════════════╝
{
    "layer": "top",
    "position": "top",
    "height": 40,
    "spacing": 0,
    "margin-top": 6,
    "margin-left": 10,
    "margin-right": 10,
    "reload_style_on_change": true,

    // ── LAYOUT — left / center / right ───────────────────────────
    "modules-left": [
        "custom/logo",
        "custom/separator",
        "hyprland/workspaces"
    ],

    "modules-center": [
        "clock"
    ],

    "modules-right": [
        "custom/gpu",
        "custom/separator",
        "custom/vram",
        "custom/separator",
        "cpu",
        "custom/separator",
        "memory",
        "custom/separator",
        "temperature",
        "custom/separator",
        "network",
        "custom/separator",
        "custom/nettraffic",
        "custom/separator",
        "custom/neuralload",
        "custom/separator",
        "custom/ai-status",
        "custom/separator",
        "pulseaudio",
        "custom/separator",
        "battery",
        "custom/separator",
        "tray",
        "custom/separator",
        "custom/ghost",
        "custom/separator",
        "custom/power"
    ],

    // ══════════════════════════════════════════════════════════════
    //  CUSTOM MODULES
    // ══════════════════════════════════════════════════════════════

    // Spider logo
    "custom/logo": {
        "format": "🕷️",
        "tooltip": false
    },

    "custom/separator": {
        "format": "│",
        "tooltip": false
    },

    "custom/ghost": {
        "format": "󰊠",
        "on-click": "kitty --title ghost-protocol -e ghost-out",
        "on-click-right": "kitty --title ghost-protocol -e ghost-out --reboot",
        "tooltip-format": "Ghost Protocol — Left: poweroff / Right: reboot"
    },

    "custom/power": {
        "format": "⏻",
        "on-click": "spider-power-menu",
        "tooltip-format": "Power Menu"
    },

    // GPU Load — RTX 3060
    "custom/gpu": {
        "exec": "nvidia-smi --query-gpu=utilization.gpu,temperature.gpu --format=csv,noheader,nounits 2>/dev/null | awk -F', ' '{printf \"󰾲 %s%%  %s°C\", $1, $2}' || echo '󰾲 N/A'",
        "return-type": "",
        "interval": 5,
        "format": "{}",
        "tooltip-format": "RTX 3060 — GPU Load &amp; Temperature"
    },

    // VRAM Usage — RTX 3060 (12GB)
    "custom/vram": {
        "exec": "nvidia-smi --query-gpu=memory.used,memory.total --format=csv,noheader,nounits 2>/dev/null | awk -F', ' '{printf \"󰍛 %.1fG / %.1fG\", $1/1024, $2/1024}' || echo '󰍛 N/A'",
        "return-type": "",
        "interval": 5,
        "format": "{}",
        "tooltip-format": "RTX 3060 — VRAM Allocation"
    },

    // ══════════════════════════════════════════════════════════════
    //  WORKSPACES
    // ══════════════════════════════════════════════════════════════

    "hyprland/workspaces": {
        "format": "{icon}",
        "format-icons": {
            "1": "I",
            "2": "II",
            "3": "III",
            "4": "IV",
            "5": "V",
            "6": "VI",
            "7": "VII",
            "8": "VIII",
            "9": "IX",
            "10": "X",
            "special": ""
        },
        "on-click": "activate",
        "sort-by-number": true,
        "persistent-workspaces": {
            "*": 5
        }
    },

    // ══════════════════════════════════════════════════════════════
    //  CLOCK
    // ══════════════════════════════════════════════════════════════

    "clock": {
        "format": "  {:%H:%M:%S}",
        "format-alt": "  {:%Y-%m-%d  %H:%M}",
        "interval": 1,
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "month",
            "weeks-pos": "left",
            "on-scroll": 1,
            "format": {
                "months": "<span color='#FC199A'><b>{}</b></span>",
                "days": "<span color='#E8E3E3'>{}</span>",
                "weeks": "<span color='#6B5F7B'>W{}</span>",
                "weekdays": "<span color='#61E2FF'><b>{}</b></span>",
                "today": "<span color='#AF6DF9'><b><u>{}</u></b></span>"
            }
        }
    },

    // ══════════════════════════════════════════════════════════════
    //  HARDWARE SENSORS
    // ══════════════════════════════════════════════════════════════

    "cpu": {
        "format": " {usage}%",
        "interval": 3,
        "states": { "warning": 70, "critical": 90 },
        "tooltip-format": "CPU Load: {usage}%\nFrequency: {avg_frequency} GHz"
    },

    "memory": {
        "format": " {percentage}%",
        "format-alt": " {used:0.1f}G / {total:0.1f}G",
        "interval": 5,
        "states": { "warning": 70, "critical": 90 },
        "tooltip-format": "RAM: {used:0.1f}G / {total:0.1f}G ({percentage}%)\nSwap: {swapUsed:0.1f}G / {swapTotal:0.1f}G"
    },

    "temperature": {
        "format": " {temperatureC}°C",
        "critical-threshold": 85,
        "tooltip-format": "CPU Thermal: {temperatureC}°C"
    },

    // ══════════════════════════════════════════════════════════════
    //  NETWORK
    // ══════════════════════════════════════════════════════════════

    "network": {
        "format-wifi": "󰤨 {signalStrength}%",
        "format-ethernet": "󰈀 {bandwidthTotalBytes}",
        "format-disconnected": "󰤭 OFF",
        "format-linked": "󰈀 {ifname}",
        "interval": 5,
        "tooltip-format-wifi": "SSID: {essid}\nSignal: {signalStrength}%\nFreq: {frequency}MHz\nIP: {ipaddr}/{cidr}\n↑ {bandwidthUpBytes}  ↓ {bandwidthDownBytes}",
        "tooltip-format-ethernet": "Interface: {ifname}\nIP: {ipaddr}/{cidr}\n↑ {bandwidthUpBytes}  ↓ {bandwidthDownBytes}",
        "tooltip-format-disconnected": "No connection. You're invisible."
    },

    "custom/nettraffic": {
        "exec": "spider-nettraffic",
        "return-type": "json",
        "interval": 3,
        "format": "{}",
        "tooltip": true
    },

    "custom/neuralload": {
        "exec": "spider-neuralload",
        "return-type": "json",
        "interval": 5,
        "format": "{}",
        "tooltip": true
    },

    // AI Status — Ollama GPU activity indicator
    "custom/ai-status": {
        "exec": "spider-aistatus",
        "return-type": "json",
        "interval": 3,
        "format": "{}",
        "on-click": "kitty --class=kitty-hazard --config=~/.config/kitty/kitty-hazard.conf -e zsh -ic 'echo -e \"\\e[36m[SPIDER-SENSE]\\e[0m Type: spider \\\"your question\\\"\\n\"; exec zsh'",
        "tooltip": true
    },

    // ══════════════════════════════════════════════════════════════
    //  AUDIO / BATTERY / TRAY
    // ══════════════════════════════════════════════════════════════

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "󰖁 MUTE",
        "format-icons": { "default": ["󰕿", "󰖀", "󰕾"] },
        "on-click": "pavucontrol",
        "tooltip-format": "Volume: {volume}%\nOutput: {desc}"
    },

    "battery": {
        "format": "{icon} {capacity}%",
        "format-charging": "󰂄 {capacity}%",
        "format-plugged": "󰚥 {capacity}%",
        "format-full": "󰁹 FULL",
        "format-icons": ["󰂎", "󰁺", "󰁻", "󰁼", "󰁽", "󰁾", "󰁿", "󰂀", "󰂁", "󰂂", "󰁹"],
        "states": { "warning": 25, "critical": 10 },
        "tooltip-format": "Battery: {capacity}%\nDraw: {power:.1f}W\n{timeTo}"
    },

    "tray": {
        "icon-size": 14,
        "spacing": 8
    }
}
